<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>Gear Hub - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <%- include('partials/sidebar') %>

    <div id="main-content" class="main-content">
        <%- include('partials/navbar') %>

        <div class="container-fluid p-4">
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card bg-primary text-white border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6>สินค้าทั้งหมด</h6>
                            <h2 class="fw-bold"><%= stats.total %></h2>
                            <small><i class="bi bi-graph-up-arrow"></i> 8 รายการใหม่</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">รับเข้าวันนี้</h6>
                            <h2 class="fw-bold text-success"><%= stats.received %></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">เบิกออกวันนี้</h6>
                            <h2 class="fw-bold text-danger"><%= stats.dispatched %></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="text-muted">สินค้าใกล้หมด</h6>
                            <h2 class="fw-bold text-warning"><%= stats.lowStock %></h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold text-secondary">พื้นที่สำหรับใส่กราฟและตารางกิจกรรม</h5>
                <p>คุณสามารถใช้ Chart.js มาวาดกราฟใส่ตรงนี้ได้เลยครับ</p>
            </div>
        </div>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>