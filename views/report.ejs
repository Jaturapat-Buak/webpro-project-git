<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>Gear Hub - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <%- include('partials/sidebar') %>
    <div id="main-content" class="main-content">
        <%- include('partials/navbar') %>
        <div class="container-fluid p-4">
            
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center h-100">
                        <h6 class="text-muted fw-bold">มูลค่าสต็อกรวมทั้งหมด</h6>
                        <h2 class="text-primary fw-bold">฿<%= summary.value.toLocaleString() %></h2>
                        <i class="bi bi-cash-coin fs-1 text-dark"></i>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center h-100">
                        <h6 class="text-muted fw-bold">จำนวนสินค้ารวมในคลัง</h6>
                        <h2 class="text-primary fw-bold"><%= summary.inventory.toLocaleString() %> <small class="fs-6">ชิ้น</small></h2>
                        <i class="bi bi-boxes fs-1 text-dark"></i>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 text-center h-100">
                        <h6 class="text-muted fw-bold">กิจกรรมทั้งหมดใน Log</h6>
                        <h2 class="text-primary fw-bold"><%= summary.logs.toLocaleString() %> <small class="fs-6">รายการ</small></h2>
                        <i class="bi bi-journal-text fs-1 text-dark"></i>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm p-4 h-100">
                        <h5 class="fw-bold mb-4">จำนวนสินค้าตามหมวดหมู่</h5>
                        <div class="chart-container" style="position: relative; height: 350px;">
                            <canvas id="reportBarChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm p-4 h-100">
                        <h5 class="fw-bold mb-4">สัดส่วนสินค้าในคลัง</h5>
                        <div class="chart-container" style="position: relative; height: 350px;">
                            <canvas id="reportPieChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const barData = <%- JSON.stringify(barData) %>;
        const pieData = <%- JSON.stringify(pieData) %>;
    </script>
    <script src="/js/script.js"></script>
    <script src="/js/report-charts.js"></script>
</body>
</html>