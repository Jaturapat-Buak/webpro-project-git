<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Edit Product</title>
</head>
<body>

    <h1>Edit Product</h1>

    <form method="POST" action="/manageproduct/<%= product.CATEGORY_ID %>/<%= product.PRODUCT_ID %>">

        <p>Product Name</p>
        <input 
            type="text" 
            name="product_name"
            value="<%= product.PRODUCT_NAME %>" 
            required
        >

        <p>Category Name</p>
        <input 
            type="text" 
            name="category_name"
            value="<%= product.CATEGORY_NAME %>" 
            required
        >
        <p>Price</p>
        <input 
            type="number" 
            step="0.01"
            name="price"
            value="<%= product.LIST_PRICE %>" 
            required
        >

        <p>Quantity</p>
        <input 
            type="number" 
            name="quantity"
            value="<%= product.QUANTITY %>" 
            required
        >

        <br><br>

        <button type="submit">Confirm</button>
        <a href="/manageproduct">Back</a>

    </form>

</body>
</html>