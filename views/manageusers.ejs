<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>manageusers</h1>
    <table class="table table-striped">
        <tr>
            <th>Username</th>
            <th>Role</th>
        </tr>

        <% data.forEach(item => { %>
            <tr>
                <td><%= item.username %></td>
                <td><%= item.role %></td>
                <td><a href="/manage/<%= item.id %>" class="btn btn-info btn-sm">Manage</a></td>
            </tr>
        <% }) %>
    </table>
    <a href = "/admin">back</a>
</body>
</html>