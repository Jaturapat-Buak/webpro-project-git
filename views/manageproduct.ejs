<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Users List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <a href="/<%= role === 'admin' ? 'admin'
            : role === 'warehousestaff' ? 'warehouse'
            : 'sales' %>">
    ← Back
    </a>
    <form method="GET" action="/manageproduct" class="mb-3">
        <div class="input-group">
            <input 
                type="text" 
                name="search" 
                class="form-control" 
                placeholder="Search product name..."
                value="<%= search || '' %>"
            >
            <button class="btn btn-primary">Search</button>
        </div>
    </form>
    <table class="table table-striped">
        <tr>
            <th>CATEGORY_ID</th>
            <th>CATEGORY_NAME</th>
            <th>PRODUCT_ID</th>
            <th>PRODUCT_NAME</th>
            <th>PRICE</th>
            <th>QUANTITY</th>
            <th>ACTION</th>
        </tr>

        <% data.forEach(item => { %>
            <tr>
                <td><%= item.CATEGORY_ID %></td>
                <td><%= item.CATEGORY_NAME %></td>
                <td><%= item.PRODUCT_ID %></td>
                <td><%= item.PRODUCT_NAME %></td>
                <td><%= item.LIST_PRICE %></td>
                <td><%= item.QUANTITY %></td>
                <td><a href="/detail/<%= item.id %>" class="btn btn-info btn-sm">Detail</a>
                <a href="/manageproduct/<%= item.CATEGORY_ID %>/<%= item.PRODUCT_ID %>" class="btn btn-info btn-sm">Manage</a>
            </tr>
        <% }) %>

    </table>

</body>
</html>
