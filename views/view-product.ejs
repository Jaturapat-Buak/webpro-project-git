<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>Gear Hub - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <%- include('partials/sidebar') %>
    <div id="main-content" class="main-content">
        <%- include('partials/navbar') %>

        <div class="container-fluid p-4 d-flex justify-content-center">
            <div class="card border-0 shadow-sm" style="max-width: 600px; width: 100%;">
                <div class="card-header bg-white p-4 text-center border-0">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-box-seam fs-1 text-info"></i>
                    </div>
                    <h4 class="fw-bold mb-1"><%= product.product_name %></h4>
                    <span class="badge bg-secondary">รหัสสินค้า: #<%= product.product_id %></span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">หมวดหมู่:</div>
                        <div class="col-sm-8"><%= product.category_name || 'ไม่มีหมวดหมู่' %></div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">ราคา:</div>
                        <div class="col-sm-8 text-primary fw-bold">$<%= (product.price || 0).toLocaleString() %></div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">สต็อกคงเหลือ:</div>
                        <div class="col-sm-8">
                            <span class="fw-bold"><%= product.stock %></span> ชิ้น
                            <% if(product.stock > 50) { %> <span class="badge bg-success ms-2">พร้อมจำหน่าย</span>
                            <% } else if(product.stock > 0) { %> <span class="badge bg-warning text-dark ms-2">ใกล้หมด</span>
                            <% } else { %> <span class="badge bg-danger ms-2">หมดสต็อก</span> <% } %>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">รายละเอียด:</div>
                        <div class="col-sm-8"><%= product.description || '-' %></div>
                    </div>
                </div>
                <div class="card-footer bg-white p-4 border-0 text-center">
                    <a href="/products" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> กลับไปหน้ารายการ</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
</body>
</html>